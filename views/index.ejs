<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Village Goose Bed & Breakfast</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>
<body>

  <%- include('partials/header') %>
        
        <div class="logo-container">
            <img src="assets/logo.png" alt="Village Goose Logo" class="logo-img">
        </div>
    </header>

    <section class="hero-section">
        <div class="hero-image-container">
            <img src="assets/full_village.png" alt="Village Goose Estate" class="hero-img">
            <a href="#hero-banner-link" class="book-stay-btn"> BOOK YOUR STAY </a>
        </div>
    </section>

    <section class="intro-section">
        <div class="intro-content">
            <h2>Enjoy a Cozy and Charming Stay</h2>
            <p>Welcome to your perfect cottage getaway. Indulge in our beautifully preserved estate, surrounded by lush gardens, timeless architecture, and the relaxing sounds of nature.</p>
        </div>
        <div class="intro-image">
            <img src="assets/cottage_with_sign.png" alt="Cottage Sign">
        </div>
    </section>

    <section class="rooms-section" id="hero-banner-link">
        <h2 class="section-title">Rooms & Suites</h2>
        <div class="rooms-grid" id="rooms-display">
            </div>
    </section>

    <section class="featured-section">
        <div class="featured-content">
            <h2>Grand Deluxe</h2>
            <p>Showcase the absolute best your property has to offer by showcasing one of your premier accommodations.</p>
            <a href="/room/6a5ad790d4fdf5b8f5f96eb9" class="availability-btn">SEE AVAILABILITY</a>
        </div>
        <div class="featured-image">
            <img src="assets/grand_deluxe2.jpg" alt="Grand Deluxe Room Layout">
        </div>
    </section>

    <section class="services-section">
        <h2 class="section-title">Our Services</h2>
        <div class="services-grid">
            <div class="service-card">
                <img src="assets/breakfast.jpg" alt="Daily Breakfast">
                <h3>Daily Breakfast</h3>
                <p>Enjoy luxury morning privileges and local dishes custom made to your complete preferences.</p>
            </div>
            <div class="service-card">
                <img src="assets/venue.jpg" alt="Event Venue">
                <h3>Event Venue</h3>
                <p>Our beautiful estate offers a special gathering atmosphere for weddings or group parties.</p>
            </div>
            <div class="service-card">
                <img src="assets/geese.jpg" alt="Geese Farm">
                <h3>Geese Farm</h3>
                <p>Take a stroll through our historical pond landscape and interact safely with our native geese population.</p>
            </div>
        </div>
    </section>
     <section class="statement">
        <div class="statement-columns">
            <div class="statement-box">
                <h3>Escape the ordinary and nestle into comfort at our peaceful cottage retreat.</h3>
            </div>
            <div class="bottom-image">
                <img src="assets/front_door.png" alt="Cottage Entrance Close Up">
            </div>
        </div>
    </section>


   <%- include('partials/footer') %>

    <script src="app.js"></script>
</body>
</html>