<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Room Details | Village Goose B&B</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- 1. NAVIGATION HEADER -->
    <%- include('partials/header') %>
    <!-- 2. FULL-WIDTH HERO SLIDER -->
    <section class="room-hero-slider">
        <div class="slider-container" id="slider-container">
            <!-- Dynamic room images will be injected here -->
            <img src="assets/blue-room.jpg" alt="Room Main Image" class="slider-img active">
        </div>
        <button class="slider-arrow prev-arrow">&#10094;</button>
        <button class="slider-arrow next-arrow">&#10095;</button>
        <div class="slider-dots" id="slider-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
        </div>
    </section>

    <!-- MAIN CONTENT CONTAINER -->
    <main class="room-page-content">
        
        <!-- 3. ROOM INTRO SPLIT PANEL -->
        <section class="room-intro-split">
            <!-- Left Side: Text Details -->
            <div class="room-text-details">
                <h1 id="room-title" class="room-page-title">Blue Room</h1>
                <p id="room-meta" class="room-page-meta">MAX 2 GUESTS / 1 QUEEN BED / $120 PER NIGHT</p>
                
                <div id="room-paragraphs" class="room-description-text">
                    <!-- Paragraph blocks injected here -->
                    <p><strong>Botanical & Beadboard Accents:</strong> The upper walls are dressed in a delicate, white-and-blue leafy botanical wallpaper...</p>
                </div>

                <div class="offers-container">
                    <h3>WHAT THIS ROOM OFFERS</h3>
                    <ul id="room-amenities-list" class="offers-list">
                        <li>Private bathroom with showerhead</li>
                        <li>Hot Water</li>
                        <li>Extra warm blankets</li>
                    </ul>
                </div>
            </div>

            <!-- Right Side: Decorative Artwork Collage -->
            <div class="room-collage-panel">
                <div class="collage-wrapper">
                    <!-- Decorative botanical line art asset -->
                    <img src="assets/botanical-line.png" alt="" class="collage-decor-icon" onerror="this.style.display='none'">
                    <img src="assets/blue-room-accent1.jpg" alt="Room detail view" class="collage-img img-top">
                    <img src="assets/blue-room-accent2.jpg" alt="Bathroom detail view" class="collage-img img-bottom">
                </div>
            </div>
        </section>

        <!-- 4. BOOKING DETAILS GRID SECTION -->
        <section class="booking-details-section">
            <h2 class="section-title">Booking Details</h2>
            
            <div class="room-booking-flow-container">
    <!-- Left Interaction Area: Calendar Panel -->
<div class="calendar-selection-panel">
        <div class="filter-ribbon">
            <div class="ribbon-box">
                <label><i class="fas fa-users"></i> Guests</label>
                <select id="booking-guests">
                    <option value="1">1 adult, 0 children</option>
                    <option value="2">2 adults, 0 children</option>
                </select>
            </div>
            <div class="ribbon-box">
                <label><i class="fas fa-calendar-alt"></i> Selected Stay Dates</label>
                <input type="text" id="date-range-picker" placeholder="Select Check-in and Check-out dates...">
            </div>
        </div>

        <!-- The Inline Double-Month Calendar Target Container -->
        <div id="inline-calendar-container"></div>

        <div class="calendar-action-bar">
            <span id="aggregate-price-preview">Select dates to view pricing options</span>
            <div>
                <a href="#" class="cancel-lnk" onclick="window.location.reload(); return false;">Cancel</a>
                <button id="reserve-stage-btn" disabled class="reserve-btn-styled">Reserve</button>
            </div>
        </div>
    </div>
    <aside class="receipt-breakout-sidebar" id="receipt-sidebar-panel" style="display: none;"></aside>
</div>
                     
        </section>

    </main>

    <!-- 5. SITE FOOTER -->
  <%- include('partials/footer') %>

</body>
</html>